---
import type { Post } from "../../../types/Post";
import BlogCard from "../../../components/BlogCard.astro";
import { getSortedPosts, getPaginatedPosts } from "../../../utils/posts";

interface Props {
  paginatedPosts: Post[];
}

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 6;
  const posts = getSortedPosts();
  const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages }).map((_, i) => {
    const page = i + 1;
    const { paginatedPosts } = getPaginatedPosts(posts, page, POSTS_PER_PAGE);
    return {
      params: { page: page.toString() },
      props: { paginatedPosts },
    };
  });
}

const { paginatedPosts } = Astro.props;
---
<div id="blog-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  {paginatedPosts.map((post: Post) => (
    <BlogCard
      title={post.title}
      description={post.description}
      date={post.date}
      link={post.url}
      tags={post.tags}
      image={post.image}
    />
  ))}
</div>